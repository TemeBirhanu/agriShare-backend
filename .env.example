PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/agriShareDB
JWT_SECRET=superSecretKeyChangeThisInProduction123!

# Blockchain (Testnet for now - Polygon Amoy)
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
PRIVATE_KEY=0xYourTestPrivateKeyHere   # NEVER commit real keys!

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Investor OTP Verification)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=test_user
SMTP_PASS=test_pass
SMTP_FROM="AgriShare <no-reply@agrishare.local>"

# Optional secret used for hashing OTP codes
OTP_SECRET=change_this_to_a_long_random_string

# Chapa Payment Integration
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CALLBACK_URL=http://localhost:5000/api/payments/webhook/chapa
CHAPA_RETURN_URL=http://localhost:5000/payment/return  # frontend displays success/failure based on this after redirect
CHAPA_WEBHOOK_SECRET=optional_static_webhook_secret
CHAPA_WITHDRAWAL_ENDPOINT=/transfers

NODE_ENV=development